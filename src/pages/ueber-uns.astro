---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHeader from "../components/PageHeader.astro";
import Icon from "../components/Icon.astro";

const timeline = [
  { year: "1972", title: "Gründung durch Georges Degoumois", text: "Der Grundstein für ein Dentallabor, das Handwerk und Innovation verbindet." },
  { year: "2013", title: "Übernahme durch Martin Svarovsky", text: "Kontinuität in Qualität und Werten – mit klarem Kurs in die digitale Zukunft." },
  { year: "Heute", title: "Digitales Labor", text: "Vollständig digitalisierte Workflows, CAD/CAM und 3D-Druck im Dienst der Präzision." },
];

const values = [
  { icon: "spark", title: "Präzision", text: "Jeder Auftrag wird von Spezialisten mit höchster Sorgfalt ausgeführt." },
  { icon: "tooth", title: "Ästhetik", text: "Zahntechnische Unikate, die in Form und Funktion überzeugen." },
  { icon: "support", title: "Vertrauen", text: "Verlässliche Partnerschaft mit Zahnärzten, Praxen und Patienten." },
  { icon: "scan", title: "Innovation", text: "Der Wille, sich ständig weiterzubilden und modernste Technologie zu nutzen." },
];
---

<BaseLayout
  title="Über uns"
  description="Die Degoumois Dental AG – ein innovatives Dentallabor in Solothurn seit 1972. Erfahren Sie mehr über unsere Philosophie, unsere Werte und unsere Geschichte."
>
  <PageHeader
    eyebrow="Über uns"
    title="Tradition trifft digitale Präzision"
    lead="Langjährige Erfahrung, umfassende Kompetenz und der Wille, kontinuierlich erstklassige Arbeit zu leisten – das ist unser Anspruch seit 1972."
    image="/img/labor/eingang-logo.jpg"
    imageAlt="Eingang Degoumois Dental AG"
  />

  <!-- Philosophie -->
  <section class="section">
    <div class="container phil-grid">
      <div data-reveal>
        <p class="eyebrow">Philosophie & Anspruch</p>
        <h2>Gegenseitiges Verständnis und Vertrauen.</h2>
        <div class="phil-img" data-reveal data-delay="1">
          <img src="/img/labor/korridor-team.jpg" alt="Team im Dentallabor Degoumois" loading="lazy" decoding="async" />
        </div>
      </div>
      <div data-reveal data-delay="2">
        <p class="lead">
          Dabei orientieren wir uns immer an den technischen Wünschen, individuellen
          Vorstellungen und persönlichen Bedürfnissen von Zahnärzten und Patienten.
        </p>
        <p>
          Denn nur gegenseitiges Verständnis und Vertrauen stellt eine hohe Zahnarzt- und
          Patientenzufriedenheit sicher. Unser qualifiziertes Team ist flexibel genug, um auf
          Ihre individuellen und spezifischen Anforderungen zu reagieren.
        </p>
      </div>
    </div>
  </section>

  <!-- Werte -->
  <section class="section" style="background:var(--surface-2);border-block:1px solid var(--line);">
    <div class="container">
      <div class="section-head" data-reveal>
        <p class="eyebrow">Unsere Werte</p>
        <h2>Worauf wir bauen</h2>
      </div>
      <div class="grid values-grid">
        {values.map((v, i) => (
          <div class="value-card card" data-reveal data-delay={(i % 4) + 1}>
            <div class="value-icon"><Icon name={v.icon} /></div>
            <h3>{v.title}</h3>
            <p>{v.text}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Geschichte -->
  <section class="section">
    <div class="container">
      <div class="section-head" data-reveal>
        <p class="eyebrow">Unsere Geschichte</p>
        <h2>Über 50 Jahre Zahntechnik</h2>
      </div>
      <ol class="timeline">
        {timeline.map((t, i) => (
          <li class="tl-item" data-reveal data-delay={(i % 3) + 1}>
            <span class="tl-year">{t.year}</span>
            <div class="tl-card card">
              <h3>{t.title}</h3>
              <p>{t.text}</p>
            </div>
          </li>
        ))}
      </ol>
    </div>
  </section>

  <!-- Leitsatz -->
  <section class="section quote-band">
    <div class="qb-photo" aria-hidden="true">
      <img src="/img/labor/korridor-kunst.jpg" alt="" loading="lazy" decoding="async" />
    </div>
    <div class="container text-center" data-reveal style="position:relative;z-index:1;">
      <blockquote>
        „Vertrauen in unsere Kompetenz ist die Basis für erstklassige Qualität.
        Dieses Motto ist für uns Verpflichtung."
      </blockquote>
      <a href="/team" class="btn btn-light" style="margin-top:2rem;">Unser Team kennenlernen <Icon name="arrow" /></a>
    </div>
  </section>
</BaseLayout>

<style>
  .phil-grid { display: grid; grid-template-columns: 0.85fr 1.15fr; gap: clamp(2rem, 5vw, 4rem); align-items: start; }
  .section-head { display: flex; flex-direction: column; align-items: center; gap: 0.8rem; text-align: center; margin-bottom: 3rem; }

  .values-grid { grid-template-columns: repeat(4, 1fr); }
  .value-card { padding: 2rem; display: flex; flex-direction: column; gap: 0.6rem; }
  .value-icon { width: 52px; height: 52px; border-radius: 14px; display: grid; place-items: center; color: var(--brand-600); background: linear-gradient(135deg, var(--brand-50), var(--brand-100)); margin-bottom: 0.5rem; font-size: 26px; }
  .value-card p { color: var(--ink-500); }

  .timeline { display: grid; grid-template-columns: repeat(3, 1fr); gap: 2rem; counter-reset: tl; }
  .tl-item { position: relative; display: flex; flex-direction: column; gap: 1rem; }
  .tl-year { font-family: var(--font-display); font-weight: 800; font-size: 1.6rem; color: var(--brand-500); }
  .tl-card { padding: 1.75rem; flex: 1; }
  .tl-card h3 { margin-bottom: 0.5rem; font-size: 1.2rem; }
  .tl-card p { color: var(--ink-500); }

  .quote-band {
    position: relative; overflow: hidden;
    background: var(--brand-950);
    color: #fff;
  }
  .qb-photo { position: absolute; inset: 0; z-index: 0; }
  .qb-photo img { width: 100%; height: 100%; object-fit: cover; object-position: center; opacity: 0.22; mix-blend-mode: luminosity; }

  .phil-img { margin-top: 2rem; border-radius: var(--radius-lg); overflow: hidden; aspect-ratio: 4/3; }
  .phil-img img { width: 100%; height: 100%; object-fit: cover; }
  blockquote { font-family: var(--font-display); font-weight: 700; font-size: clamp(1.4rem, 3vw, 2.1rem); line-height: 1.3; color: #fff; max-width: 24ch; margin-inline: auto; letter-spacing: -0.01em; }

  @media (max-width: 900px) {
    .phil-grid { grid-template-columns: 1fr; }
    .values-grid { grid-template-columns: repeat(2, 1fr); }
    .timeline { grid-template-columns: 1fr; }
  }
  @media (max-width: 520px) { .values-grid { grid-template-columns: 1fr; } }
</style>
