---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import Hero from "../components/Hero.astro";
import PartnerStrip from "../components/PartnerStrip.astro";
import NewsCard from "../components/NewsCard.astro";
import Icon from "../components/Icon.astro";
import { services } from "../data/services";
import { site } from "../site";

const latestNews = (await getCollection("news", ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);

const stats = [
  { value: "50+", label: "Jahre Erfahrung seit 1972" },
  { value: "10+", label: "Implantatsysteme im Einsatz" },
  { value: "100%", label: "Made in Solothurn" },
];
---

<BaseLayout hero>
  <Hero />

  <!-- Intro -->
  <section class="section" id="intro">
    <div class="container intro-grid">
      <div data-reveal>
        <p class="eyebrow">Ihr Dentallabor in Solothurn</p>
        <h2>Präzision, die man sieht – Partnerschaft, die man spürt.</h2>
      </div>
      <div data-reveal data-delay="1">
        <p class="lead">
          Wir sind ein innovatives, leistungsstarkes und kundenorientiertes Dentallabor.
          Unsere Arbeiten zeichnen sich durch gutes Handwerk, hohe Präzision und grosse
          Flexibilität aus.
        </p>
        <p>
          Qualität, kompetente Fachberatung und Zuverlässigkeit schaffen Vertrauen für eine
          partnerschaftliche Zusammenarbeit. Unter der Führung des Gründers Georges Degoumois
          hat sich das Labor seit 1972 stetig weiterentwickelt – 2013 übernahm Martin Svarovsky
          das Unternehmen und führt es mit demselben Anspruch in die digitale Zukunft.
        </p>
        <a href="/ueber-uns" class="btn btn-ghost" style="margin-top:1.5rem;">
          Mehr über uns <Icon name="arrow" />
        </a>
      </div>
    </div>
  </section>

  <!-- Leistungen -->
  <section class="section" style="background:var(--surface-2);border-block:1px solid var(--line);">
    <div class="container">
      <div class="section-head" data-reveal>
        <p class="eyebrow">Unsere Leistungen</p>
        <h2>Massgeschneiderte Zahntechnik</h2>
        <p class="lead mx-auto text-center">
          Präzision, Ästhetik und moderne Technologie – vereint in Lösungen, die zu Ihrer Praxis passen.
        </p>
      </div>
      <div class="grid services-grid">
        {services.map((s, i) => (
          <a href={`/leistungen#${s.slug}`} class="service-card card" data-reveal data-delay={(i % 3) + 1}>
            <div class="service-icon"><Icon name={s.icon} /></div>
            <h3>{s.title}</h3>
            <p>{s.short}</p>
            <span class="service-link">Mehr erfahren <Icon name="arrow" /></span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <PartnerStrip />

  <!-- Stimmungsbild / Impact -->
  <section class="section photo-band">
    <div class="photo-band-inner">
      <div class="photo-item" data-reveal>
        <img src="/img/labor/zahnmodell.jpg" alt="Zahntechnisches Modell – Degoumois Dental" loading="lazy" decoding="async" />
      </div>
      <div class="photo-item" data-reveal data-delay="1">
        <img src="/img/labor/farbbestimmung.jpg" alt="Farbbestimmung einer Zahnkrone" loading="lazy" decoding="async" />
      </div>
      <div class="photo-item" data-reveal data-delay="2">
        <img src="/img/labor/kunstbild.jpg" alt="Kunstwerk im Degoumois Dental Labor" loading="lazy" decoding="async" />
      </div>
    </div>
  </section>

  <!-- Werte / Stats -->
  <section class="section values">
    <div class="container values-grid">
      <div class="values-text" data-reveal>
        <p class="eyebrow">Unsere Werte</p>
        <h2>Vertrauen in unsere Kompetenz ist die Basis für erstklassige Qualität.</h2>
        <p>
          Alle eingesetzten Werkstoffe erfüllen höchste zahnmedizinische Standards. Jeder
          Auftrag wird mit Präzision und Engagement ausgeführt – das Ergebnis ist ein
          qualitativ hochwertiges, zahntechnisches Unikat, das in Ästhetik und Funktion
          keine Wünsche offen lässt.
        </p>
        <a href="/kontakt" class="btn btn-primary" style="margin-top:1.5rem;">
          Zusammenarbeit starten <Icon name="arrow" />
        </a>
      </div>
      <ul class="stats">
        {stats.map((s, i) => (
          <li data-reveal data-delay={i + 1}>
            <span class="stat-value">{s.value}</span>
            <span class="stat-label">{s.label}</span>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <!-- News-Teaser -->
  <section class="section" style="background:var(--surface-2);border-top:1px solid var(--line);">
    <div class="container">
      <div class="section-head-row" data-reveal>
        <div>
          <p class="eyebrow">Aktuelles</p>
          <h2>News aus dem Labor</h2>
        </div>
        <a href="/news" class="btn btn-ghost">Alle News <Icon name="arrow" /></a>
      </div>
      <div class="grid news-grid">
        {latestNews.map((entry, i) => (
          <div data-reveal data-delay={(i % 3) + 1}><NewsCard entry={entry} /></div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="cta">
    <div class="cta-photo" aria-hidden="true">
      <img src="/img/labor/diplome.jpg" alt="" loading="lazy" decoding="async" />
    </div>
    <div class="container cta-inner" data-reveal style="position:relative;z-index:1;">
      <h2>Bereit für eine reibungslose Zusammenarbeit?</h2>
      <p>Senden Sie uns Ihren Auftrag oder vereinbaren Sie eine persönliche Beratung – wir freuen uns auf Sie.</p>
      <div class="cta-actions">
        <a href={`tel:${site.phone.replace(/\s/g,"")}`} class="btn btn-light"><Icon name="phone" /> {site.phoneDisplay}</a>
        <a href="/kontakt" class="btn btn-primary">Kontakt aufnehmen <Icon name="arrow" /></a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .intro-grid { display: grid; grid-template-columns: 0.85fr 1.15fr; gap: clamp(2rem, 5vw, 4rem); align-items: start; }
  .section-head { display: flex; flex-direction: column; align-items: center; gap: 0.8rem; text-align: center; margin-bottom: 3.5rem; }
  .section-head h2 { max-width: 18ch; }
  .section-head-row { display: flex; justify-content: space-between; align-items: flex-end; gap: 1.5rem; margin-bottom: 3rem; flex-wrap: wrap; }

  .services-grid { grid-template-columns: repeat(3, 1fr); }
  .service-card { display: flex; flex-direction: column; gap: 0.75rem; padding: 2rem; }
  .service-icon {
    width: 56px; height: 56px; border-radius: 16px; margin-bottom: 0.5rem;
    display: grid; place-items: center; color: var(--brand-600); font-size: 28px;
    background: linear-gradient(135deg, var(--brand-50), var(--brand-100));
  }
  .service-card p { color: var(--ink-500); flex: 1; }
  .service-link { display: inline-flex; align-items: center; gap: 0.4em; font-family: var(--font-display); font-weight: 600; color: var(--brand-600); font-size: 0.92rem; }
  .service-link svg { width: 1.05em; transition: transform 0.25s var(--ease); }
  .service-card:hover .service-link svg { transform: translateX(4px); }

  .values-grid { display: grid; grid-template-columns: 1.3fr 0.7fr; gap: clamp(2rem, 5vw, 4rem); align-items: center; }
  .values-text h2 { font-size: clamp(1.6rem, 2.6vw, 2.3rem); margin-block: 1rem; }
  .stats { display: flex; flex-direction: column; gap: 1rem; }
  .stats li {
    background: linear-gradient(135deg, var(--brand-600), var(--brand-900));
    color: #fff; border-radius: var(--radius-lg); padding: 1.75rem 2rem;
    display: flex; flex-direction: column;
  }
  .stat-value { font-family: var(--font-display); font-weight: 800; font-size: 2.6rem; line-height: 1; }
  .stat-label { color: rgba(255,255,255,0.8); margin-top: 0.4rem; }

  .news-grid { grid-template-columns: repeat(3, 1fr); }

  /* Photo Band */
  .photo-band { padding-block: 0; overflow: hidden; }
  .photo-band-inner { display: grid; grid-template-columns: repeat(3, 1fr); height: clamp(220px, 30vw, 400px); }
  .photo-item { overflow: hidden; }
  .photo-item img { width: 100%; height: 100%; object-fit: cover; object-position: center; transition: transform 0.6s var(--ease); }
  .photo-item:hover img { transform: scale(1.04); }

  .cta {
    position: relative; overflow: hidden;
    background: linear-gradient(160deg, var(--brand-800), var(--brand-950));
    color: #fff; padding-block: clamp(4rem, 8vw, 6.5rem);
  }
  .cta-photo { position: absolute; inset: 0; z-index: 0; }
  .cta-photo img { width: 100%; height: 100%; object-fit: cover; object-position: center; opacity: 0.18; mix-blend-mode: luminosity; }
  .cta-inner { text-align: center; max-width: 640px; }
  .cta-inner h2 { color: #fff; }
  .cta-inner p { color: rgba(255,255,255,0.82); margin-block: 1rem 2rem; font-size: 1.1rem; }
  .cta-actions { display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap; }

  @media (max-width: 900px) {
    .intro-grid, .values-grid { grid-template-columns: 1fr; }
    .services-grid { grid-template-columns: repeat(2, 1fr); }
    .news-grid { grid-template-columns: 1fr; }
  }
  @media (max-width: 560px) { .services-grid { grid-template-columns: 1fr; } }
</style>
