---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHeader from "../components/PageHeader.astro";
import PartnerStrip from "../components/PartnerStrip.astro";
import Icon from "../components/Icon.astro";
import { services } from "../data/services";

const serviceListSchema = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  itemListElement: services.map((s, i) => ({
    "@type": "ListItem",
    position: i + 1,
    name: s.title,
    description: s.description,
  })),
};
---

<BaseLayout
  title="Leistungen & Fachgebiete"
  description="Das Leistungsspektrum der Degoumois Dental AG: CAD/CAM, Implantatprothetik, Vollkeramik, Prothetik, digitaler Workflow und umfassender Service – Zahntechnik aus Solothurn."
>
  <PageHeader
    eyebrow="Fachgebiete"
    title="Unser Leistungsspektrum"
    lead="Von der digitalen Konstruktion bis zur fertigen Restauration – Präzision, Ästhetik und moderne Zahntechnik aus einer Hand."
    image="/img/labor/farbbestimmung.jpg"
    imageAlt="Farbbestimmung einer Zahnkrone bei Degoumois Dental"
  />

  <section class="section">
    <div class="container">
      <div class="svc-list">
        {services.map((s, i) => (
          <article id={s.slug} class="svc-row" data-reveal>
            <div class="svc-aside">
              <div class="svc-num">{String(i + 1).padStart(2, "0")}</div>
              <div class="svc-icon"><Icon name={s.icon} /></div>
            </div>
            <div class="svc-main">
              <h2>{s.title}</h2>
              <p class="lead">{s.description}</p>
              <ul class="svc-points">
                {s.points.map((p) => (
                  <li><Icon name="check" class="chk" /> {p}</li>
                ))}
              </ul>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <PartnerStrip title="Systeme & Materialien" subtitle="Wir verarbeiten ausschliesslich Werkstoffe, die höchste zahnmedizinische Standards erfüllen." />

  <section class="section service-band">
    <div class="sb-photo" aria-hidden="true">
      <img src="/img/labor/empfang.jpg" alt="" loading="lazy" decoding="async" />
    </div>
    <div class="container text-center" data-reveal style="position:relative;z-index:1;">
      <p class="eyebrow mx-auto" style="justify-content:center;">Service inklusive</p>
      <h2 class="mx-auto" style="max-width:20ch;">Erfahrung und Kompetenz seit mehr als 50 Jahren</h2>
      <ul class="service-points">
        <li><Icon name="check" class="chk" /> Erreichbarkeit das ganze Jahr hindurch</li>
        <li><Icon name="check" class="chk" /> Eigener Kurierdienst – termingerecht</li>
        <li><Icon name="check" class="chk" /> Professioneller Patientenraum mit Wartebereich</li>
        <li><Icon name="check" class="chk" /> Varianten & detaillierte Kostenberechnungen</li>
        <li><Icon name="check" class="chk" /> Planbesprechungen mit Zahnärzten</li>
        <li><Icon name="check" class="chk" /> Flexibel auch bei kurzfristigen Abgabeterminen</li>
        <li><Icon name="check" class="chk" /> Farbbestimmung im Labor oder in der Praxis</li>
        <li><Icon name="check" class="chk" /> 3D-Implantatplanung & digitale Falldokumentation</li>
      </ul>
      <a href="/kontakt" class="btn btn-primary" style="margin-top:2.5rem;">Auftrag erteilen <Icon name="arrow" /></a>
    </div>
  </section>

  <script type="application/ld+json" set:html={JSON.stringify(serviceListSchema)} is:inline />
</BaseLayout>

<style>
  .svc-list { display: flex; flex-direction: column; gap: clamp(2.5rem, 5vw, 4.5rem); }
  .svc-row { display: grid; grid-template-columns: 120px 1fr; gap: clamp(1.5rem, 4vw, 3rem); padding-bottom: clamp(2.5rem, 5vw, 4.5rem); border-bottom: 1px solid var(--line); scroll-margin-top: calc(var(--header-h) + 2rem); }
  .svc-row:last-child { border-bottom: none; padding-bottom: 0; }
  .svc-aside { display: flex; flex-direction: column; gap: 1rem; align-items: flex-start; }
  .svc-num { font-family: var(--font-display); font-weight: 800; font-size: 2rem; color: var(--brand-200); }
  .svc-icon {
    width: 64px; height: 64px; border-radius: 18px; display: grid; place-items: center;
    color: #fff; background: linear-gradient(135deg, var(--brand-500), var(--brand-800)); font-size: 32px;
  }
  .svc-main h2 { font-size: clamp(1.5rem, 2.6vw, 2.1rem); margin-bottom: 0.75rem; }
  .svc-points { display: grid; grid-template-columns: repeat(2, 1fr); gap: 0.6rem 1.5rem; margin-top: 1.5rem; }
  .svc-points li, .service-points li { display: flex; align-items: flex-start; gap: 0.6rem; color: var(--ink-700); font-weight: 500; }
  :global(.chk) { width: 20px; height: 20px; color: var(--brand-500); flex-shrink: 0; margin-top: 3px; }

  .service-band {
    position: relative; overflow: hidden;
    background: var(--brand-950);
    color: #fff;
    border-top: none;
  }
  .service-band .eyebrow { color: var(--brand-300); }
  .service-band h2, .service-band li { color: #fff; }
  .service-band li { color: rgba(255,255,255,0.9); }
  :global(.service-band .chk) { color: var(--brand-300); }
  .sb-photo { position: absolute; inset: 0; z-index: 0; }
  .sb-photo img { width: 100%; height: 100%; object-fit: cover; object-position: center 30%; opacity: 0.2; mix-blend-mode: luminosity; }
  .service-points {
    display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 0.8rem 2rem;
    max-width: 760px; margin: 2.5rem auto 0; text-align: left;
  }
  @media (max-width: 700px) {
    .svc-row { grid-template-columns: 1fr; }
    .svc-aside { flex-direction: row; align-items: center; }
    .svc-points, .service-points { grid-template-columns: 1fr; }
  }
</style>
