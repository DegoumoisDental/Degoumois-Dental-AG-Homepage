---
import { site } from "../site";
---

<section class="hero">
  <!-- ============================================================
       HEADER-VIDEO – PLATZHALTER
       Sobald die Videosequenz vorliegt: Datei unter
       /public/video/hero.mp4 (+ optional hero.webm) ablegen.
       Das <video> wird dann automatisch über dem Verlauf abgespielt.
       ============================================================ -->
  <div class="hero-media" aria-hidden="true">
    <div class="hero-gradient"></div>
    <video
      class="hero-video"
      autoplay
      muted
      loop
      playsinline
      preload="auto"
      poster="/img/hero-poster.svg"
    >
      <source src="/video/hero.mp4" type="video/mp4" />
      <source src="/video/hero.webm" type="video/webm" />
    </video>
    <div class="hero-overlay"></div>
  </div>

  <div class="container-wide hero-inner">
    <div class="hero-content">
      <p class="hero-eyebrow" data-reveal>Dentallabor · Solothurn · seit {site.founded}</p>
      <h1 data-reveal data-delay="1">
        Mehr als <span class="grad-text">Zahntechnik.</span>
      </h1>
      <p class="hero-lead" data-reveal data-delay="2">
        Wir vereinen Präzision, moderne Technologie und individuelle Lösungen für
        hochwertigen Zahnersatz – mit einem starken Netzwerk und spürbarer
        Entlastung im Praxisalltag.
      </p>
      <div class="hero-actions" data-reveal data-delay="3">
        <a href="/leistungen" class="btn btn-light">
          Unsere Leistungen
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
        </a>
        <a href="/kontakt" class="btn btn-primary">Auftrag erteilen</a>
      </div>
      <a href="#intro" class="hero-scroll" aria-label="Weiter scrollen" data-reveal data-delay="4">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
          <polyline points="6 9 12 15 18 9"/>
        </svg>
      </a>
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    min-height: 100svh;
    display: flex;
    align-items: center;
    overflow: hidden;
    color: #fff;
  }
  .hero-media { position: absolute; inset: 0; z-index: 0; }
  .hero-gradient {
    position: absolute; inset: 0;
    background:
      radial-gradient(120% 80% at 15% 20%, #1a86bd 0%, transparent 55%),
      radial-gradient(120% 90% at 85% 15%, #2ea7d9 0%, transparent 50%),
      linear-gradient(155deg, #0c3a55 0%, #0c6492 45%, #08293d 100%);
    background-size: 160% 160%;
    animation: heroFlow 22s ease-in-out infinite;
  }
  @keyframes heroFlow {
    0%, 100% { background-position: 0% 50%; }
    50% { background-position: 100% 50%; }
  }
  .hero-video {
    position: absolute; inset: 0;
    width: 100%; height: 100%;
    object-fit: cover;
  }
  .hero-overlay {
    position: absolute; inset: 0;
    background: linear-gradient(180deg, rgba(8,41,61,0.55) 0%, rgba(8,41,61,0.25) 40%, rgba(8,41,61,0.75) 100%);
  }
.hero-inner { position: relative; z-index: 2; padding-top: var(--header-h); }
  .hero-content { max-width: 760px; }
  .hero-eyebrow {
    font-family: var(--font-display);
    font-weight: 600; font-size: 0.85rem;
    letter-spacing: 0.18em; text-transform: uppercase;
    color: rgba(255,255,255,0.82);
    margin-bottom: 1.25rem;
  }
  .hero h1 { color: #fff; margin-bottom: 1.5rem; }
  .grad-text {
    background: linear-gradient(120deg, #a8dbf1, #6ec3e8);
    -webkit-background-clip: text; background-clip: text; color: transparent;
  }
  .hero-lead {
    font-size: clamp(1.1rem, 1.7vw, 1.4rem);
    color: rgba(255,255,255,0.9);
    max-width: 56ch; margin-bottom: 2.25rem;
  }
  .hero-actions { display: flex; flex-wrap: wrap; gap: 1rem; }

  .hero-scroll {
    display: inline-flex;
    margin-top: 2.5rem;
    color: rgba(255,255,255,0.75);
    transition: color 0.25s var(--ease);
    animation: arrowBounce 2s ease-in-out infinite;
  }
  .hero-scroll svg {
    width: 36px; height: 36px;
  }
  .hero-scroll:hover { color: #fff; }
  @keyframes arrowBounce {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(8px); }
  }
</style>
