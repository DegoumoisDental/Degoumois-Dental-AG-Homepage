<div class="stoerer" id="jobStoerer" aria-live="polite" aria-label="Stellenausschreibung">
  <button class="stoerer-close" id="stoererClose" aria-label="Schliessen">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round">
      <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
    </svg>
  </button>

  <div class="stoerer-inner">
    <p class="stoerer-eyebrow">✨ Wir suchen Verstärkung</p>
    <h2 class="stoerer-title">Dein Talent,<br>unsere Zukunft! 🚀</h2>
    <p class="stoerer-body">
      Werde Teil eines modernen Dentallabors in Solothurn und gestalte die Zukunft der Zahntechnik mit uns! 🦷
    </p>
    <ul class="stoerer-list">
      <li>✅ Zahntechniker/in EFZ (m/w/d)</li>
      <li>💡 Abwechslungsreiche Aufgaben</li>
      <li>🤝 Starkes, eingespieltes Team</li>
    </ul>
    <a href="/kontakt" class="stoerer-btn">
      Jetzt bewerben &amp; durchstarten
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
    </a>
  </div>
</div>

<style>
  .stoerer {
    position: fixed;
    bottom: 2rem;
    right: 2rem;
    width: 340px;
    z-index: 9999;
    border-radius: 1.25rem;
    overflow: hidden;
    box-shadow: 0 24px 64px rgba(8, 41, 61, 0.35), 0 4px 16px rgba(8, 41, 61, 0.2);
    background: rgba(12, 58, 85, 0.82);
    backdrop-filter: saturate(160%) blur(14px);
    -webkit-backdrop-filter: saturate(160%) blur(14px);
    color: #fff;
    transform: translateX(calc(100% + 2.5rem));
    opacity: 0;
    transition: transform 0.55s cubic-bezier(0.34, 1.56, 0.64, 1), opacity 0.4s ease;
    will-change: transform, opacity;
  }
  .stoerer.is-visible {
    transform: translateX(0);
    opacity: 1;
  }
  .stoerer.is-hidden {
    transform: translateX(calc(100% + 2.5rem));
    opacity: 0;
    pointer-events: none;
  }

  .stoerer-close {
    position: absolute;
    top: 0.85rem;
    right: 0.85rem;
    width: 2rem;
    height: 2rem;
    border-radius: 50%;
    background: rgba(255,255,255,0.15);
    border: none;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #fff;
    transition: background 0.2s;
    backdrop-filter: blur(4px);
  }
  .stoerer-close:hover { background: rgba(255,255,255,0.28); }
  .stoerer-close svg { width: 14px; height: 14px; }

  .stoerer-inner {
    padding: 1.75rem 1.6rem 1.6rem;
  }

  .stoerer-eyebrow {
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.7);
    margin-bottom: 0.6rem;
  }

  .stoerer-title {
    font-size: 1.65rem;
    font-weight: 800;
    line-height: 1.15;
    margin-bottom: 0.9rem;
    color: #fff;
  }

  .stoerer-body {
    font-size: 0.93rem;
    color: rgba(255,255,255,0.88);
    line-height: 1.55;
    margin-bottom: 1rem;
  }

  .stoerer-list {
    list-style: none;
    padding: 0;
    margin: 0 0 1.4rem;
    display: flex;
    flex-direction: column;
    gap: 0.45rem;
  }
  .stoerer-list li {
    font-size: 0.92rem;
    font-weight: 600;
    color: rgba(255,255,255,0.95);
  }

  .stoerer-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    width: 100%;
    padding: 0.85em 1.2em;
    background: #fff;
    color: #0c3a55;
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 0.95rem;
    border-radius: 0.75rem;
    text-decoration: none;
    transition: background 0.2s, transform 0.2s, box-shadow 0.2s;
    box-shadow: 0 4px 16px rgba(0,0,0,0.18);
  }
  .stoerer-btn svg { width: 1.1em; height: 1.1em; transition: transform 0.2s; }
  .stoerer-btn:hover {
    background: #e8f6fd;
    transform: translateY(-1px);
    box-shadow: 0 8px 24px rgba(0,0,0,0.22);
  }
  .stoerer-btn:hover svg { transform: translateX(4px); }

  @media (max-width: 480px) {
    .stoerer {
      bottom: 0;
      right: 0;
      left: 0;
      width: 100%;
      border-radius: 1.25rem 1.25rem 0 0;
      transform: translateY(calc(100% + 1rem));
    }
    .stoerer.is-visible { transform: translateY(0); }
    .stoerer.is-hidden { transform: translateY(calc(100% + 1rem)); }
  }
</style>

<script>
  function initStoerer() {
    const el = document.getElementById("jobStoerer");
    const closeBtn = document.getElementById("stoererClose");
    if (!el || !closeBtn) return;

    const dismissed = sessionStorage.getItem("stoerer-dismissed");
    if (dismissed) return;

    const timer = setTimeout(() => {
      el.classList.add("is-visible");
      setTimeout(() => {
        el.classList.remove("is-visible");
        el.classList.add("is-hidden");
        sessionStorage.setItem("stoerer-dismissed", "1");
      }, 10000);
    }, 2500);

    closeBtn.addEventListener("click", () => {
      el.classList.remove("is-visible");
      el.classList.add("is-hidden");
      sessionStorage.setItem("stoerer-dismissed", "1");
      clearTimeout(timer);
    });
  }
  initStoerer();
  document.addEventListener("astro:after-swap", initStoerer);
</script>
