---
interface Props { name: string; class?: string; }
const { name, class: cls = "" } = Astro.props;

const paths: Record<string, string> = {
  cube: '<path d="M12 2 3 7v10l9 5 9-5V7z"/><path d="M3 7l9 5 9-5M12 12v10"/>',
  implant: '<path d="M9 3h6M12 3v6M8 9h8l-1 5a3 3 0 0 1-6 0z"/><path d="M11 19l1 2 1-2"/>',
  tooth: '<path d="M12 5c2-2 5-2 6 1 1 3-1 6-1 9 0 2-1 4-2 4s-1-3-3-3-2 3-3 3-2-2-2-4c0-3-2-6-1-9 1-3 4-3 6-1z"/>',
  crown: '<path d="M3 8l4 4 5-7 5 7 4-4v9H3z"/>',
  scan: '<path d="M4 7V5a1 1 0 0 1 1-1h2M17 4h2a1 1 0 0 1 1 1v2M20 17v2a1 1 0 0 1-1 1h-2M7 20H5a1 1 0 0 1-1-1v-2M4 12h16"/>',
  support: '<path d="M21 12a9 9 0 1 0-18 0M3 12v3a2 2 0 0 0 2 2h1v-5H3zm18 0h-3v5h1a2 2 0 0 0 2-2z"/>',
  check: '<path d="M20 6 9 17l-5-5"/>',
  arrow: '<path d="M5 12h14M13 6l6 6-6 6"/>',
  phone: '<path d="M22 16.9v3a2 2 0 0 1-2.2 2 19.8 19.8 0 0 1-8.6-3 19.5 19.5 0 0 1-6-6 19.8 19.8 0 0 1-3-8.6A2 2 0 0 1 4.1 2h3a2 2 0 0 1 2 1.7c.1.9.4 1.8.7 2.6a2 2 0 0 1-.5 2.1L8.1 9.9a16 16 0 0 0 6 6l1.5-1.2a2 2 0 0 1 2.1-.5c.8.3 1.7.6 2.6.7a2 2 0 0 1 1.7 2z"/>',
  mail: '<path d="M4 4h16a2 2 0 0 1 2 2v12a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2z"/><path d="m22 6-10 7L2 6"/>',
  pin: '<path d="M21 10c0 7-9 12-9 12s-9-5-9-12a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/>',
  clock: '<circle cx="12" cy="12" r="9"/><path d="M12 7v5l3 2"/>',
  spark: '<path d="M12 2v6M12 16v6M2 12h6M16 12h6M5 5l3 3M16 16l3 3M19 5l-3 3M8 16l-3 3"/>',
};
const d = paths[name] ?? "";
---
<svg class={cls} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" set:html={d} />

<style>
  /* Standardgröße: skaliert mit font-size des Containers (1em). */
  svg { width: 1em; height: 1em; display: inline-block; vertical-align: -0.125em; flex-shrink: 0; }
</style>
